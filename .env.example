# PostgreSQL / TimescaleDB
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=demo_db

# Redis
REDIS_PASSWORD=change-me-redis-password

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=0
# L3: set to your actual hostname/IP for production; avoid committing private LAN IPs
ALLOWED_HOSTS=localhost,127.0.0.1

# API Security
API_KEY=change-me-to-a-random-api-key

# Django demo actions (seed/clear) toggle
# C3: only IPs listed here may call seed/clear when ENABLE_MUTATIONS=1
ENABLE_MUTATIONS=0
MUTATION_ALLOWED_IPS=127.0.0.1

# H1: set to your public origin for production (e.g. https://your-domain.com)
CORS_ORIGIN=http://localhost:8000
